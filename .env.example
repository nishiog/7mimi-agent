# Keep real secrets out of agent-runner containers.
# claude-proxy owns Claude provider credentials. auth-proxy / MCP servers own external API credentials.

# X API / XMCP
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_API_TOOL_ALLOWLIST=searchPostsRecent,getPosts,getUsers,getUsersByUsername

# J-Quants MCP
JQUANTS_API_KEY=

# Claude proxy
# ANTHROPIC_API_KEY is for claude-proxy only. Do not mount it into agent-runner containers.
CLAUDE_PROXY_URL=http://localhost:18080
CLAUDE_PROXY_SECRET_DIR=.secrets/claude
CLAUDE_PROXY_SESSION_TOKEN_TTL_SECONDS=3600

# Claude provider credential for claude-proxy only. Do not mount into agent-runner containers.
ANTHROPIC_API_KEY=

# --- Resident stack (docker compose, ADR-024) ---

# Bearer shared by auth-proxy's git relay (ADR-020) and x-mcp (ADR-023).
# Runner/scheduler send this same value as X_MCP_SESSION_TOKEN / GIT_PROXY_SESSION_TOKEN.
AUTH_PROXY_SESSION_TOKEN=

# X API bearer token consumed by auth-proxy's x-mcp-readonly endpoint (ADR-023).
X_BEARER_TOKEN=

# Slack incoming webhook URL consumed by auth-proxy's /v1/slack/notify
# endpoint (ADR-026). Optional: unset disables the route and the
# invest-x-daily-digest job cannot publish. Never mounted into agent-runner.
SLACK_WEBHOOK_URL=

# GitHub App "7mimi-agent" (ADR-020). Used by auth-proxy's git relay to mint
# short-lived installation access tokens; do not commit the private key.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
# 絶対パスでホスト上の秘密鍵(.pem)を指定する。docker-compose.yml が
# read-only でコンテナの /secrets/github-app-key.pem にマウントする。
GITHUB_APP_PRIVATE_KEY_HOST_PATH=

# claude-proxy に対する開発用セッション token。scheduler コンテナが
# CLAUDE_PROXY_SESSION_TOKEN として送出する(未設定時は cp_sess_dev を使用)。
CLAUDE_PROXY_DEV_TOKEN=

# scheduler コンテナが自身とリポジトリを同一絶対パスでマウントするための
# ホスト側リポジトリの絶対パス。未設定時は `docker compose` 実行時の $PWD を使う。
REPO_ROOT=
