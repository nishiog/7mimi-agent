# syntax=docker/dockerfile:1
FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# git: needed by scheduler-side helpers that shell out to git (clone-back
# verification etc., ADR-021).
#
# No docker CLI here (Issue #29 / k3s deploy): in-cluster, the scheduler
# dispatches runner tasks via KubernetesRunnerBackend, which talks to the
# k8s API directly over HTTPS (stdlib urllib) instead of a sibling
# `docker run` on a mounted host socket. The docker.sock sibling-container
# path (ContainerRunnerBackend, ADR-024) remains for docker-compose local/dev
# use only, and that compose profile is *not* built from this image anymore
# -- run compose's scheduler service against an image that still bundles the
# `docker` CLI, or exec `docker` from the host, if you need --runner
# container from inside a container.
RUN apt-get update \
 && apt-get install -y --no-install-recommends git ca-certificates \
 && apt-get clean && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml README.md ./
COPY src ./src

RUN pip install --upgrade pip \
 && pip install -e .

# Single-root invariant (config/loader.py find_project_root): both
# docker-compose (repo bind-mounted at an identical host path, see
# docker-compose.yml, which also overrides working_dir explicitly) and k8s
# (ConfigMap at /app/config, PVC at /app/.data and /app/.sessions,
# deploy/k8s/scheduler.yaml) converge on /app (set above) as the project
# root the process runs from.

ENTRYPOINT []
CMD ["python", "-m", "shichimimi_agent", "schedule", "run"]
