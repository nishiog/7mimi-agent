# syntax=docker/dockerfile:1
FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY pyproject.toml README.md ./
COPY src ./src

RUN pip install --upgrade pip \
 && pip install -e .

# Runtime normally mounts the project repository at /workspace and runs there.
WORKDIR /workspace

ENTRYPOINT []
CMD ["python", "-m", "sevenmimi_agent", "config", "validate"]
